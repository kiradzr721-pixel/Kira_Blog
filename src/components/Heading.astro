---
import { invariant } from '@/lib/ensure'
import { cn } from '@/lib/style'
import type { HTMLTag, Polymorphic } from 'astro/types'
import clsx from 'clsx'

type HeadingElement = 'h1' | 'h2' | 'h3' | 'h4' | 'h5' | 'h6'

/**
 * Standalone heading component for use outside of `.prose` contexts with
 * styling that visually matches prose headings for consistency but without the margins.
 *
 * Beware Astro's Polymorphic typing is buggy as all hell and a constant source of
 * issues and frustration. We have no choice but to provide a default and the internal
 * typing will make it optional even though we don't want that.
 */
type Props<Tag extends HTMLTag = 'h1'> = Polymorphic<{
	as: Tag
}> & {
	styleAs?: HeadingElement
}

const { as: Tag = 'h1', styleAs, class: className, ...restProps } = Astro.props
const visualSize: HeadingElement = styleAs ?? (Tag as HeadingElement)

const validTags = ['h1', 'h2', 'h3', 'h4', 'h5', 'h6']

// runtime validation to make up for astro's broken typing
invariant(Astro.props.as, "Heading.astro requires explicit `as` prop despite Astro's borked polymorphic typing")
invariant(validTags.includes(String(Tag)), "Heading.astro `as` value must be one of 'h1' to 'h6'")

// h1 and h2 use clamp() for fluid scaling — math mirrors the prose utility.
// The vw coefficient is multiplied by 1.125 to preserve the fluid curve
// at the standalone context (prose base is 1.125rem; standalone has no base).
//
// static sizes derived from prose em multipliers × 1.125rem (prose base):
//   h1 max:     2.25    × 1.125rem = 2.53125rem
//   h2 max:     1.625   × 1.125rem = 1.828125rem
//   h3: 1.25    × 1.125rem = 1.40625rem
//   h4: 1.0625  × 1.125rem = 1.1953125rem
//   h5: 0.875   × 1.125rem = 0.984375rem
//   h6: 0.8125  × 1.125rem = 0.9140625rem
//
// all values are wrapped in clsx() below to enable tailwind intellisense and help with debugging

const sizeClasses: Record<HeadingElement, string> = {
	h1: clsx('text-[clamp(1.96875rem,1.40625rem+2.8125vw,2.53125rem)] leading-[1.15] tracking-[-0.03em] font-bold'),
	h2: clsx('text-[clamp(1.546875rem,1.2375rem+1.575vw,1.828125rem)] leading-tight tracking-tight font-bold'),
	h3: clsx('text-[1.40625rem] font-semibold leading-[1.35] tracking-[-0.015em]'),
	h4: clsx('text-[1.1953125rem] font-semibold leading-[1.4] tracking-[-0.01em]'),
	h5: clsx('text-[0.984375rem] font-bold leading-[1.4] tracking-wide uppercase'),
	h6: clsx('text-[0.9140625rem] font-bold leading-[1.4] tracking-wide uppercase'),
}
---

<Tag class={cn('text-P-heading text-balance', sizeClasses[visualSize], className)} {...restProps}>
	<slot />
</Tag>
