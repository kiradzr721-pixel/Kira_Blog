---
import type { CollectionEntry } from 'astro:content'
import FormattedDate from '@/components/FormattedDate.astro'
import { cn } from '@/lib/style'

/**
 * Reusable blog post card.
 *
 * Usage:
 *   <PostCard post={post} />                    – default variant
 *   <PostCard post={post} variant="featured" />  – shows "Pinned" label
 *
 * The card is a white rounded-2xl surface with subtle shadow.
 * On hover it lifts 4px with a slightly deeper shadow.
 * No scale, no gradient, no colored backgrounds.
 */

interface Props {
	post: CollectionEntry<'blog'>
	variant?: 'default' | 'featured'
	class?: string
}

const { post, variant = 'default', class: className } = Astro.props
const isFeatured = variant === 'featured'
---

<a
	href={`/blog/${post.id}/`}
	class={cn('group block', className)}
	aria-label={isFeatured ? `Pinned: ${post.data.title}` : post.data.title}
>
	<article
		class={cn(
			'h-full bg-P-surface rounded-2xl p-6',
			'border border-P-border',
			'card-shadow',
			'hover:card-shadow-hover hover:-translate-y-1',
			'transition-all duration-300 ease-out',
		)}
	>
		{
			isFeatured && (
				<span class="text-tiny font-medium uppercase tracking-widest text-P-muted mb-3 block">
					Pinned
				</span>
			)
		}
		<h2 class="text-xl font-semibold text-P-heading text-balance leading-snug
			group-hover:text-P-link-hover transition-colors duration-200">
			{post.data.title}
		</h2>
		<FormattedDate
			date={post.data.publishedAt}
			class="block mt-2 text-sm text-P-subtle"
		/>
		{
			post.data.description && (
				<p class="mt-2 text-sm text-P-subtle leading-relaxed line-clamp-2">
					{post.data.description}
				</p>
			)
		}
	</article>
</a>
