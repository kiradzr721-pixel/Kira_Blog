---
import { cn } from '@/lib/style'

type Props = {
	class?: string
}

const { class: className } = Astro.props as Props

const features = [
	{
		title: 'TailwindCSS',
		description: 'Complete with palette and typography.',
	},
	{
		title: 'Markdown & MDX',
		description: 'Easily write content with elegant styling.',
	},
	{
		title: 'SEO',
		description: 'Meta helper covers standard & social tags.',
	},
	{
		title: 'Sitemap',
		description: 'Generates sitemap.xml with sane defaults.',
	},
	{
		title: 'Robots',
		description: 'robots.txt welcomes search engines.',
	},
	{
		title: 'Pure Astro',
		description: 'Clean start with zero frameworks.',
	},
]
---

<div class={cn('grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 w-full mx-auto gap-6', className)}>
	{
		features.map((feature) => (
			<div class="flex flex-col bg-P-card text-P-card-fg border rounded-xl py-5 sm:py-6 px-5">
				<h3 class="text-h4 text-P-heading">{feature.title}</h3>
				<p class="mt-1 text-P-lead text-pretty">{feature.description}</p>
			</div>
		))
	}
</div>
